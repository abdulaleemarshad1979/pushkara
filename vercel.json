{
  "version": 2,
  "rewrites": [
    { "source": "/sitemap.xml",            "destination": "/pushkaralu_fixed/dashboards/sitemap.xml" },
    { "source": "/robots.txt",             "destination": "/pushkaralu_fixed/dashboards/robots.txt" },
    { "source": "/admin",                  "destination": "/pushkaralu_fixed/dashboards/admin.html" },
    { "source": "/volunteer",              "destination": "/pushkaralu_fixed/dashboards/index.html" },
    { "source": "/user",                   "destination": "/pushkaralu_fixed/dashboards/user.html" },
    { "source": "/config.js",              "destination": "/pushkaralu_fixed/dashboards/config.js" },
    { "source": "/manifest.json",          "destination": "/pushkaralu_fixed/dashboards/manifest.json" },
    { "source": "/sw.js",                  "destination": "/pushkaralu_fixed/dashboards/sw.js" },
    { "source": "/icon-192.svg",           "destination": "/pushkaralu_fixed/dashboards/icon-192.svg" },
    { "source": "/icon-512.svg",           "destination": "/pushkaralu_fixed/dashboards/icon-512.svg" },
    { "source": "/icon-maskable.svg",      "destination": "/pushkaralu_fixed/dashboards/icon-maskable.svg" },
    { "source": "/icon-96.png",            "destination": "/pushkaralu_fixed/dashboards/icon-96.png" },
    { "source": "/icon-192.png",           "destination": "/pushkaralu_fixed/dashboards/icon-192.png" },
    { "source": "/icon-512.png",           "destination": "/pushkaralu_fixed/dashboards/icon-512.png" },
    { "source": "/icon-maskable-512.png",  "destination": "/pushkaralu_fixed/dashboards/icon-maskable-512.png" },
    { "source": "/screenshot-narrow.png",  "destination": "/pushkaralu_fixed/dashboards/screenshot-narrow.png" },
    { "source": "/screenshot-wide.png",    "destination": "/pushkaralu_fixed/dashboards/screenshot-wide.png" },
    { "source": "/",                       "destination": "/pushkaralu_fixed/dashboards/user.html" }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/user",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/volunteer",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Content-Type",           "value": "application/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type",  "value": "application/manifest+json; charset=utf-8" }
      ]
    },
    {
      "source": "/(icon-.*\\.svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" },
        { "key": "Content-Type",  "value": "image/svg+xml" }
      ]
    },
    {
      "source": "/(icon-.*\\.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" },
        { "key": "Content-Type",  "value": "image/png" }
      ]
    },
    {
      "source": "/(screenshot-.*\\.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" },
        { "key": "Content-Type",  "value": "image/png" }
      ]
    }
  ]
}
