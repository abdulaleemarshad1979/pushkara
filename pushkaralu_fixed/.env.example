# ─────────────────────────────────────────────────────────────────────────────
# Godavari Pushkaralu 2027 — Environment Variables  (PRODUCTION TEMPLATE)
#
# Copy this file to `.env` and fill in real values BEFORE deploying.
# The application refuses to start in production mode if the secrets below
# are missing or set to known-insecure defaults — this is intentional.
#
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime mode ─────────────────────────────────────────────────────────────
# Set to "development" ONLY for local work. Any other value (including unset)
# enables strict secret validation and CORS allow-listing.
ENVIRONMENT=production


# ── JWT (volunteer authentication) ───────────────────────────────────────────
# Must be at least 32 characters. Anything shorter is rejected at boot.
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_FROM_secrets.token_hex(32)
JWT_EXPIRY_HOURS=8


# ── Admin portal credentials (used by POST /admin/login) ─────────────────────
# These gate the handover of ADMIN_API_KEY to the in-page login modal.
# ADMIN_PASSWORD must be at least 12 characters and not on the deny-list.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSPHRASE_AT_LEAST_12_CHARS


# ── Admin API key (used by /admin/* endpoints via X-Admin-Key header) ────────
# Never embedded in static JavaScript. Only handed to the browser session
# after successful POST /admin/login.
ADMIN_API_KEY=REPLACE_WITH_64_CHAR_HEX_FROM_secrets.token_hex(32)


# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API. Browsers are
# blocked from any origin not in this list.
CORS_ALLOWED_ORIGINS=https://pushkara.vercel.app,https://www.pushkara.vercel.app


# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Render free-tier Postgres connection string. The application falls back to
# in-memory storage if this is unreachable, but durability requires Postgres.
DATABASE_URL=postgresql://pushkaralu:CHANGE_ME@localhost/pushkaralu
POSTGRES_PASSWORD=CHANGE_ME
DB_MIN_POOL=2
DB_MAX_POOL=8


# ── Redis (cache + pub/sub + rate-limit + leader election) ───────────────────
# On Render free tier, set ENABLE_REDIS=true and provide REDIS_URL.
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS=true


# ── Object storage (Cloudflare R2 / AWS S3) — OPTIONAL ───────────────────────
# Leave blank to fall back to local-disk uploads (good enough for free tier).
# Set these for durable image hosting (lost-person photos, issue images).
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_REGION=ap-south-1
S3_PUBLIC_BASE_URL=
S3_ACL=


# ── WhatsApp / Mana Mitra integration — OPTIONAL ─────────────────────────────
# Default provider is "mock" so the app never crashes for missing credentials.
# Switch WHATSAPP_PROVIDER to "twilio" / "mana_mitra" / "meta" once the
# corresponding credential block below is populated.
WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=mock
WHATSAPP_DEFAULT_COUNTRY_CODE=91
WHATSAPP_PUBLIC_NUMBER=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

MANA_MITRA_API_URL=
MANA_MITRA_API_KEY=
MANA_MITRA_SENDER_ID=PUSHKARALU

META_WA_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_VERIFY_TOKEN=pushkaralu-verify
META_GRAPH_VERSION=v20.0


# ── Misc tuning ──────────────────────────────────────────────────────────────
SCRAPERBOT_URL=http://localhost:3000
CROWD_BROADCAST_INTERVAL=2.5
INSTANCE_ID=api-1
UPLOAD_MAX_MB=5
LEADER_TTL_SECONDS=10
HEAL_MEM_WARN_MB=550
HEAL_MEM_CRIT_MB=700
GROQ_API_KEY=
